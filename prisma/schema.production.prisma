// Prisma schema for Assistudio Vigevano MVP
// Docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─── Auth (NextAuth v5) ───────────────────────────────────────────────────────

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─── Users & Roles ───────────────────────────────────────────────────────────

enum Role {
  ADMIN
  AGENT
  CLIENT
}

model User {
  id           String    @id @default(cuid())
  email        String    @unique
  name         String
  role         Role      @default(CLIENT)
  passwordHash String?   // null for magic-link (CLIENT) users
  emailVerified DateTime?
  image        String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  accounts      Account[]
  sessions      Session[]
  agentClients  ClientAgent[]
  clientProfile Client?
  auditLogs     AuditLog[]
}

// ─── Clients ─────────────────────────────────────────────────────────────────

model Client {
  id            String    @id @default(cuid())
  codiceFiscale String    @unique
  firstName     String
  lastName      String
  email         String?
  phone         String?
  address       String?
  notes         String?
  archivedAt    DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  userId   String?       @unique
  user     User?         @relation(fields: [userId], references: [id])
  agents   ClientAgent[]
  policies Policy[]
  documents Document[]
  requests  ContactRequest[]
}

model ClientAgent {
  clientId  String
  agentId   String
  assignedAt DateTime @default(now())

  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)
  agent  User   @relation(fields: [agentId], references: [id], onDelete: Cascade)

  @@id([clientId, agentId])
}

// ─── Policies ────────────────────────────────────────────────────────────────

enum PolicyCategory {
  AUTO
  CASA
  VITA
  SALUTE
  INFORTUNI
  IMPRESA
  TUTELA_LEGALE
  VIAGGIO
  ALTRO
}

enum PolicyStatus {
  ACTIVE
  EXPIRING
  RENEWED
  CANCELLED
}

model Policy {
  id               String         @id @default(cuid())
  policyNumber     String         @unique
  insuranceCompany String
  category         PolicyCategory
  premiumCents     Int
  startDate        DateTime
  renewalDate      DateTime
  status           PolicyStatus   @default(ACTIVE)
  notes            String?
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  clientId  String
  client    Client     @relation(fields: [clientId], references: [id], onDelete: Cascade)
  documents Document[]
}

// ─── Documents ───────────────────────────────────────────────────────────────

enum DocumentType {
  POLIZZA
  CERTIFICATO
  FATTURA
  SINISTRO
  ALTRO
}

model Document {
  id           String       @id @default(cuid())
  fileName     String
  fileUrl      String
  fileSize     Int
  mimeType     String
  docType      DocumentType @default(ALTRO)
  uploadedById String
  deletedAt    DateTime?
  createdAt    DateTime     @default(now())

  clientId String?
  client   Client? @relation(fields: [clientId], references: [id])
  policyId String?
  policy   Policy? @relation(fields: [policyId], references: [id])
}

// ─── Contact Requests ────────────────────────────────────────────────────────

enum ContactRequestStatus {
  RECEIVED
  IN_PROGRESS
  CLOSED
}

model ContactRequest {
  id            String               @id @default(cuid())
  subject       String
  body          String @db.Text
  attachmentUrl String?
  status        ContactRequestStatus @default(RECEIVED)
  createdAt     DateTime             @default(now())
  updatedAt     DateTime             @updatedAt

  clientId String
  client   Client @relation(fields: [clientId], references: [id], onDelete: Cascade)
}

// ─── Audit Log ───────────────────────────────────────────────────────────────

model AuditLog {
  id         String   @id @default(cuid())
  userId     String
  action     String
  entityType String
  entityId   String
  meta       Json?
  createdAt  DateTime @default(now())

  user User @relation(fields: [userId], references: [id])
}
